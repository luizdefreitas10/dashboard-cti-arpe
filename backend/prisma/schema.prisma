generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Atividade {
  id          String    @id @default(cuid())
  categoria   String
  nome        String
  diaSemana   String?
  data        DateTime?
  horario     String?
  responsavel String?
  solicitante String?
  setor       String?
  prioridade  String?
  estado      String?
  observacao  String?
  createdAt   DateTime  @default(now())

  @@map("atividades")
}

model Bem {
  id                  String  @id @default(cuid())
  tombamento          String  @unique
  tipoHardware        String?
  modelo              String?
  usuario             String?
  setor               String?
  finalidadePrincipal String?
  sistemaOperacional  String?
  criticidade         String?

  @@map("bens")
}

/// Histórico de alterações de bens (registrado em cada importação de planilha)
model BemHistorico {
  id           String   @id @default(cuid())
  tombamento   String
  operacao     String   /// criado | alterado | removido
  campo        String?  /// campo alterado (setor, usuario, etc) quando operacao=alterado
  valorAnterior String?
  valorNovo    String?
  importLogId  String?
  createdAt    DateTime @default(now())

  @@index([tombamento])
  @@index([createdAt(sort: Desc)])
  @@map("bens_historico")
}

model Software {
  id         String  @id @default(cuid())
  nome       String
  versao     String?
  finalidade String?

  @@map("softwares")
}

model Ramal {
  id        String  @id @default(cuid())
  setor     String
  digital   Int     @default(0)
  analogico Int     @default(0)
  total     Int     @default(0)
  descricao String?

  @@map("ramais")
}

model Celular {
  id     String @id @default(cuid())
  modelo String
  setor  String
  imei   String @unique

  @@map("celulares")
}

/// Dashboards Power BI publicados pela CTI (carga via planilha em /importar)
model PowerBiReport {
  id          String   @id @default(cuid())
  nome        String
  link        String   @unique
  descricao   String?
  autores     String?
  /// concluido | em_andamento
  status      String   @default("concluido")
  /// Nome do arquivo em /public/power-bi/ ou URL absoluta (https://...)
  imagem      String?
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("power_bi_reports")
}

/// Soluções digitais CTI — carga via planilha SOLUCOES-DIGITAIS-CTI.xlsx em /importar
model SolucaoDigital {
  id             String    @id @default(cuid())
  /// automacao | solucao_web
  tipo           String
  nome           String
  descricao      String?
  setor          String?
  stack          String?
  /// Coluna LINK (GitHub)
  urlRepositorio String?
  /// Nome arquivo em /public/solucoes-digitais/ ou URL https
  imagem         String?
  responsavel    String?
  dataInicio     DateTime?
  /// Texto bruto da coluna OBSERVACOES
  observacoes    String?
  /// concluida | em_andamento (parse OBSERVACOES)
  statusProjeto  String
  /// URL extraída de "Concluída - https://..."
  urlProducao    String?
  ordem          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("solucoes_digitais")
}

/// Histórico de importações de planilhas (auditoria / frescor dos dados)
model DataImportLog {
  id        String   @id @default(cuid())
  /// atividades | bens | power_bi | solucoes_digitais
  tipo      String
  filename  String?
  rowsCount Int?
  message   String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("data_import_logs")
}
